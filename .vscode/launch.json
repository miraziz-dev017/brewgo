{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run BrewGo Bot (uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["bot_server:app", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
